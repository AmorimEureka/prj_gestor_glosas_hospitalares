# Use http://localhost:8000 quando rodar o Django direto no WSL.
# Use http://host.docker.internal:8000 quando rodar o frontend em Docker.
API_BASE_URL=http://host.docker.internal:8000
API_CONTA_ATENDIMENTO_PATH=/app_glosas/
API_REGISTRO_GLOSA_PATH=/app_glosas/glosas
API_TIMEOUT=60
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=1
SESSION_COOKIE_AGE=28800
SESSION_COOKIE_SECURE=0
